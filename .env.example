# Optional helper for local signing.
# Do not put the real value in GitHub.
ALARM_CONFIG_HMAC_SECRET=replace-with-private-signing-secret

# Optional local MCU notification for Codex/Gemini done alerts.
# Do not put real local URLs or tokens in GitHub.
MCU_NOTIFY_MODE=auto
MCU_NOTIFY_URL=
MCU_NOTIFY_TOKEN=replace-with-local-token-if-enabled
MCU_NOTIFY_PORT=COM4
MCU_NOTIFY_EFFECT=10
